# Server
HOST=0.0.0.0
PORT=8000
# Comma-separated list of browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000
# PCM input format expected by the WebSocket endpoint. Do not change these
# unless the browser audio encoder and transcription pipeline change too.
AUDIO_SAMPLE_RATE=16000
AUDIO_BUFFER_SECONDS=2

# Firebase Admin
# Store this JSON outside source control. Relative paths are resolved from backend/.
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
# Alternatively, your application may load the entire service-account JSON from this variable.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Local Whisper
# Typical values: tiny, base, small, medium, large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_DOWNLOAD_ROOT=./models/whisper

# Local Ollama. When running without Docker, Ollama normally listens here.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
